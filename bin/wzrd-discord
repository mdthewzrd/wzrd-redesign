#!/bin/bash

# WZRD Discord Bot Launcher
# Starts the topic-aware Discord bot

WZRD_ROOT="/home/mdwzrd/wzrd-redesign"
BOT_JS="$WZRD_ROOT/interfaces/discord-bot.js"
CONFIG="$WZRD_ROOT/interfaces/discord-config.yaml"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log() { echo -e "${GREEN}[WZRD-DISCORD]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Check if compiled
if [ ! -f "$BOT_JS" ]; then
    error "Discord bot not compiled. Run: cd interfaces && npx tsc discord-bot.ts"
    exit 1
fi

# Check config
if [ ! -f "$CONFIG" ]; then
    error "Config not found: $CONFIG"
    exit 1
fi

# Parse command
case "${1:-start}" in
    start)
        log "Starting Discord bot..."
        cd "$WZRD_ROOT/interfaces"
        node discord-bot.js
        ;;
    test)
        log "Starting in TEST MODE..."
        log "Mock WebSocket server will start on ws://localhost:8765"
        cd "$WZRD_ROOT/interfaces"
        TEST_MODE=true node discord-bot.js
        ;;
    stop)
        log "Stopping Discord bot..."
        pkill -f "discord-bot.js" 2>/dev/null || echo "Bot not running"
        ;;
    status)
        if pgrep -f "discord-bot.js" > /dev/null; then
            log "Discord bot is running"
            ps aux | grep discord-bot | grep -v grep
        else
            warn "Discord bot is not running"
        fi
        ;;
    *)
        echo "Usage: $0 {start|test|stop|status}"
        echo ""
        echo "Commands:"
        echo "  start  - Start Discord bot (requires token)"
        echo "  test   - Start in test mode (mock WebSocket)"
        echo "  stop   - Stop Discord bot"
        echo "  status - Check bot status"
        ;;
esac
