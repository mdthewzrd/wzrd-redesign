#!/bin/bash
# 🚀 WZRD Hot Client - Connect to running OpenCode server for instant commands
# Uses persistent server instead of cold starts (13.4s → ~100ms)

set -e

# Configuration
DEFAULT_PORT=${PORT:-8080}
DEFAULT_HOSTNAME=${HOSTNAME:-mdwzrd}  # Changed from localhost to mdwzrd
SERVER_URL="http://$DEFAULT_HOSTNAME:$DEFAULT_PORT"
CACHE_DIR="$HOME/.cache/wzrd-hot"
ATTACHED_SESSION_FILE="$CACHE_DIR/attached.session"

# Create cache directory
mkdir -p "$CACHE_DIR"

echo "🚀 WZRD Hot Client"
echo "=================="

# Check if already attached
if [ -f "$ATTACHED_SESSION_FILE" ]; then
    echo "✅ Already attached to server"
    SERVER_URL=$(cat "$ATTACHED_SESSION_FILE")
    echo "Server URL: $SERVER_URL"
else
    # Check if server is running
    echo "🔍 Checking for running server..."
    
    if curl -s "$SERVER_URL/health" >/dev/null 2>&1; then
        echo "✅ Server found at $SERVER_URL"
    else
        echo "❌ No server found at $SERVER_URL"
        echo ""
        echo "Start server first:"
        echo "  ./wzrd-hot-server"
        echo ""
        echo "Or specify custom server:"
        echo "  SERVER_URL=http://host:port ./wzrd-hot-client [command]"
        exit 1
    fi
    
    # Attach to server
    echo ""
    echo "🔗 Attaching to server..."
    
    # Save session
    echo "$SERVER_URL" > "$ATTACHED_SESSION_FILE"
    echo "✅ Attached to $SERVER_URL"
fi

# Extract command
if [ $# -eq 0 ]; then
    echo ""
    echo "Usage: ./wzrd-hot-client [command]"
    echo "Example: ./wzrd-hot-client 'echo test'"
    echo ""
    echo "Or run in interactive mode:"
    echo "  ./wzrd-hot-client"
    echo ""
    exit 0
fi

COMMAND="$*"

echo ""
echo "⚡ Executing: $COMMAND"
echo "Server: $SERVER_URL"
echo ""

# Execute command via attached session
START_TIME=$(date +%s%N)

echo "🔗 Attaching to: $SERVER_URL"
echo "📝 Command: $COMMAND"

# First attach to server (creates persistent session)
ATTACH_OUTPUT=$(timeout 5 opencode attach "$SERVER_URL" 2>&1)
ATTACH_EXIT=$?

if [ $ATTACH_EXIT -eq 0 ]; then
    echo "✅ Successfully attached"
    
    # Now run command in the attached session
    echo "⚡ Running command..."
    COMMAND_OUTPUT=$(timeout 5 opencode run "$COMMAND" 2>&1)
    
    END_TIME=$(date +%s%N)
    RUNTIME_MS=$(( (END_TIME - START_TIME) / 1000000 ))
    
    echo "📋 Output:"
    echo "$COMMAND_OUTPUT" | head -20
    
    echo ""
    echo "📊 Performance:"
    echo "  Hot connection: ${RUNTIME_MS}ms"
    echo "  Cold start: ~13,400ms"
    if [ "$RUNTIME_MS" -gt 0 ]; then
        SPEEDUP=$(echo "scale=0; 13400 / $RUNTIME_MS" | bc)
        echo "  Speedup: ~${SPEEDUP}× faster!"
    else
        echo "  Speedup: Could not calculate"
    fi
else
    echo "❌ Failed to attach"
    echo "Attach output: $ATTACH_OUTPUT"
    echo ""
    echo "Try:"
    echo "1. Check server is running: ./wzrd-hot-server"
    echo "2. Try direct: opencode attach $SERVER_URL"
    echo "3. Clear session: rm -f $ATTACHED_SESSION_FILE"
    exit 1
fi