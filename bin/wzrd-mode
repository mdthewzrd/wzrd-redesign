#!/bin/bash
# WZRD.dev Production Launch System
# Default: Launch new production system (old system preserved as legacy)

# Check if resource gate is blocking
if [ -f /home/mdwzrd/wzrd-resource-gate.sh ]; then
    # Temporarily bypass for first launch
    export RESOURCES_BLOCKED=0
fi

# Launch production system by default
echo "🚀 WZRD.dev Production System"
echo "============================"
echo ""
echo "Starting production-ready system with:"
echo "• Process monitoring & resource control"
echo "• Skill registry (20 skills)"
echo "• Multi-channel API (CLI/Discord)"
echo "• Blueprint workflows"
echo "• 97% token efficiency"
echo ""
echo "Use 'wzrd.dev --legacy' for original system"
echo ""

exec /home/mdwzrd/wzrd-dev-launch.sh

# Show help
if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  echo "Usage: wzrd [OPTIONS] [PROMPT]"
  echo "Options:"
  echo "  --mode MODE    Set mode (chat, thinker, coder, debug, research)"
  echo "  --model MODEL  Override model (default: from mode config)"
  echo "  --health       Show system health report"
  echo "  --validate     Run Phase 1 validation"
  echo "  --skills       List skills for current mode"
  echo "  --compact      Run true compact workflow (save & reset)"
  echo "  --compact-auto Start auto-monitoring"
  echo "  --compact-stat Show chat statistics"
  echo "  --true-compact True compact (actually deletes messages like Claude)"
  echo "  --compact-mon  Start auto-monitor (80K token threshold)"
  echo "  --help, -h     Show this help"
  echo "  (no args)      Launch OpenCode TUI"
  echo ""
  echo "Examples:"
  echo "  wzrd                         # Launch TUI in chat mode"
  echo "  wzrd --mode thinker          # Launch TUI in thinker mode"
  echo "  wzrd --mode coder 'Fix bug'  # Run prompt in coder mode"
  echo "  wzrd --health                # Show system health"
  echo "  wzrd --validate              # Validate Phase 1 systems"
  exit 0
fi

# Health check
if [[ "$1" == "--health" ]]; then
  echo "🩺 Running WZRD System Health Check..."
  node bin/health-monitor.js
  exit 0
fi

# Validation check
if [[ "$1" == "--validate" ]]; then
  echo "🔍 Running Phase 1 Validation..."
  node bin/validate-phase1.js
  exit 0
fi

# Compact workflow
if [[ "$1" == "--compact" ]]; then
  echo "🔧 Running True Compact Workflow..."
  ./integrated-wzrd-compact.sh manual
  exit 0
fi

if [[ "$1" == "--compact-auto" ]]; then
  echo "🔧 Starting Auto-Monitoring..."
  ./integrated-wzrd-compact.sh auto
  exit 0
fi

if [[ "$1" == "--compact-stat" ]]; then
  echo "📊 Showing Chat Statistics..."
  ./integrated-wzrd-compact.sh stats
  exit 0
fi

# True compact (actually deletes messages)
if [[ "$1" == "--true-compact" ]]; then
  echo "🧹 Running WZRD True Compact (like Claude)..."
  ./wzrd-compact-solution.sh compact
  exit 0
fi

# Start auto-monitor
if [[ "$1" == "--compact-mon" ]]; then
  echo "🔍 Starting WZRD Compact Monitor (80K token threshold)..."
  ./wzrd-compact-solution.sh monitor
  exit 0
fi

# Skills list
if [[ "$1" == "--skills" ]]; then
  MODE="${2:-chat}"
  MODE_FILE="./remi/modes/$MODE.md"
  
  if [[ ! -f "$MODE_FILE" ]]; then
    echo "❌ Mode '$MODE' not found"
    exit 1
  fi
  
  echo "🛠️ Skills for $MODE mode:"
  
  # Map modes to skills (from skills-integration.md)
  case $MODE in
    chat)
      echo "  • orchestration - Agent coordination"
      echo "  • context - Context management"
      echo "  • planning - Task breakdown"
      echo "  • communication - User interaction"
      ;;
    thinker)
      echo "  • architecture - System design"
      echo "  • planning - Project planning"
      echo "  • research - Information gathering"
      echo "  • validation - Input verification"
      ;;
    coder)
      echo "  • coding - Implementation"
      echo "  • debugging - Problem-solving"
      echo "  • testing - QA and validation"
      echo "  • git - Version control"
      ;;
    debug)
      echo "  • debugging - Troubleshooting"
      echo "  • testing - Test strategy"
      echo "  • performance - Optimization"
      echo "  • system-health - Monitoring"
      ;;
    research)
      echo "  • research - Investigation"
      echo "  • web-search - Information discovery"
      echo "  • data-analysis - Data processing"
      echo "  • documentation - Technical writing"
      ;;
    *)
      echo "  • (Default skills)"
      ;;
  esac
  
  echo ""
  echo "📊 Token optimization: 4-5 skills loaded (~40KB) vs 65+ skills (~637KB)"
  exit 0
fi

echo "🚀 WZRD.dev launching from: $(pwd)"
echo "📁 Ecosystem: remi/, topics/, memory/, skills/, etc."

# Default mode
MODE="chat"
MODEL=""
PROMPT_ARGS=()

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --mode)
      MODE="$2"
      shift 2
      ;;
    --model)
      MODEL="$2"
      shift 2
      ;;
    *)
      PROMPT_ARGS+=("$1")
      shift
      ;;
  esac
done

# Load mode configuration
MODES_DIR="./remi/modes"
MODE_FILE="$MODES_DIR/$MODE.md"

if [[ ! -f "$MODE_FILE" ]]; then
  echo "❌ Mode '$MODE' not found. Available modes:"
  ls "$MODES_DIR"/*.md | sed 's|.*/||' | sed 's/\.md//'
  exit 1
fi

# Extract model from mode file if not specified
if [[ -z "$MODEL" ]]; then
  MODEL=$(grep -E "^primary_model:" "$MODE_FILE" | cut -d: -f2 | tr -d ' ')
  if [[ -z "$MODEL" ]]; then
    MODEL="nvidia/z-ai/glm4.7"  # Default fallback
  fi
fi

echo "🤖 Mode: $MODE"
echo "🧠 Model: $MODEL"
echo "📄 Mode config: $MODE_FILE"

# Auto-detect mode from prompt if chat mode
if [[ "$MODE" == "chat" && ${#PROMPT_ARGS[@]} -gt 0 ]]; then
  PROMPT="${PROMPT_ARGS[*]}"
  
  # Use enhanced auto-mode detector
  AUTO_MODE_RESULT=$(node -e "
    const AutoModeDetector = require('./bin/auto-mode-detector.js').default || require('./bin/auto-mode-detector.js');
    const detector = new AutoModeDetector();
    const result = detector.detectMode('$PROMPT');
    console.log(\`\${result.mode}:\${result.confidence}\`);
  " 2>/dev/null || echo "chat:0.00")
  
  if [[ "$AUTO_MODE_RESULT" =~ ^([^:]+):([0-9.]+)$ ]]; then
    DETECTED_MODE="${BASH_REMATCH[1]}"
    CONFIDENCE="${BASH_REMATCH[2]}"
    
    if (( $(echo "$CONFIDENCE > 0.3" | bc -l 2>/dev/null || echo 0) )); then
      echo "🔍 Auto-detected: $DETECTED_MODE mode (confidence: ${CONFIDENCE})"
      MODE="$DETECTED_MODE"
      
      # Set appropriate model for each mode
      case "$DETECTED_MODE" in
        "coder"|"thinker"|"debug")
          MODEL="nvidia/deepseek-ai/deepseek-v3.2"
          ;;
        "research")
          MODEL="nvidia/moonshotai/kimi-k2.5"
          ;;
        *)
          MODEL="nvidia/deepseek-ai/deepseek-v3.2"
          ;;
      esac
    else
      echo "🔍 Low confidence auto-detection (${CONFIDENCE}), staying in chat mode"
    fi
  else
    echo "⚠️ Auto-mode detection failed, using chat mode"
  fi
fi

# Show skill loading for mode
  echo "🛠️ Loading skills for $MODE mode..."
  case $MODE in
    chat)
      echo "  • orchestration, team-communication-protocols, topic-switcher, auto-memory"
      ;;
    thinker)
      echo "  • architecture, planning, research, validation"
      ;;
    coder)
      echo "  • coding, refactoring, testing, git"
      ;;
    debug)
      echo "  • debugging, testing, performance, system-health"
      ;;
    research)
      echo "  • research, web-search, data-analysis, documentation"
      ;;
  esac
echo "📊 Token savings: ~90% reduction vs loading all skills"

# Check if Remi agent exists
if [[ -f "./remi/SOUL.md" ]]; then
  echo "🧠 Remi agent available"
  AGENT="--agent remi"
else
  echo "⚠️  Remi agent not found"
  AGENT=""
fi

# Add memory system context if available
  if [[ -f "./memory/unified-memory.js" && ${#PROMPT_ARGS[@]} -gt 0 ]]; then
    echo "🧠 Memory system available for context enhancement"
    
    # Search memory for relevant context
    echo "🔍 Searching memory for relevant context..."
    MEMORY_RESULTS=$(node -e "
      try {
        const fs = require('fs');
        const path = require('path');
        const topicsPath = path.join(__dirname, 'memory', 'topics');
        
        function searchMemory(query) {
          const results = [];
          
          function searchDir(dir) {
            if (!fs.existsSync(dir)) return;
            
            const items = fs.readdirSync(dir);
            for (const item of items) {
              const fullPath = path.join(dir, item);
              const stat = fs.statSync(fullPath);
              
              if (stat.isDirectory()) {
                searchDir(fullPath);
              } else if (stat.isFile() && (item.endsWith('.md') || item.endsWith('.txt') || item.includes('conversation-'))) {
                try {
                  const content = fs.readFileSync(fullPath, 'utf8');
                  const lines = content.split('\\n');
                  
                  lines.forEach((line, index) => {
                    if (line.toLowerCase().includes(query.toLowerCase())) {
                      results.push({
                        file: path.relative(__dirname, fullPath),
                        line: index + 1,
                        content: line.trim().substring(0, 80) + '...'
                      });
                    }
                  });
                } catch (e) {
                  // Skip
                }
              }
            }
          }
          
          if (fs.existsSync(topicsPath)) {
            searchDir(topicsPath);
          }
          
          return results.slice(0, 3); // Top 3 results
        }
        
        const query = '${PROMPT_ARGS[*]}';
        const results = searchMemory(query);
        
        if (results.length > 0) {
          console.log('\\n📚 Found relevant memory:');
          results.forEach((r, i) => {
            console.log(\`  • \${r.file}:\${r.line} - \"\${r.content}\"\`);
          });
          console.log('');
        }
      } catch (e) {
        // Silent fail if memory search fails
      }
    " 2>/dev/null || true)
    
    # Capture conversation after execution
    if [[ $EXIT_CODE -eq 0 ]]; then
      echo "💾 Capturing conversation to memory..."
      # Extract last response for capture (this would need response from OpenCode)
      # For now, capture the query and mode
      node bin/capture-conversation.js capture "${PROMPT_ARGS[*]} (Mode: $MODE)" "wzrd-mode" >/dev/null 2>&1 &
    fi
  fi

# Launch OpenCode
  if [[ ${#PROMPT_ARGS[@]} -eq 0 ]]; then
    # No args = launch OpenCode TUI
    echo "🌐 Launching OpenCode TUI..."
    
    # Start WZRD compact monitor in background if not already running
    if [ ! -f "$HOME/.local/state/opencode/wzrd-backups/monitor.pid" ] || \
       ! ps -p $(cat "$HOME/.local/state/opencode/wzrd-backups/monitor.pid" 2>/dev/null) >/dev/null 2>&1; then
      echo "🔍 Starting WZRD Compact Monitor (80K token auto-compact)..."
      (cd ~/wzrd-redesign && ./wzrd-compact-solution.sh monitor >/dev/null 2>&1 &)
    fi
    
    # Show current token usage
    CURRENT_TOKENS=$(cd ~/wzrd-redesign && ./wzrd-compact-solution.sh check)
    echo "📊 Current token estimate: $CURRENT_TOKENS (auto-compact at 80,000)"
    
    # Launch OpenCode
    opencode --model "$MODEL" $AGENT
  else
    # Has args = run command with mode context
    echo "💬 Running with prompt: ${PROMPT_ARGS[*]}"

    # 🚀 PARALLEL EXECUTION OPTIMIZATION - START ALL NON-BLOCKING PROCESSES IN BACKGROUND
    echo "🚀 Parallel optimization enabled"
    
    # Enhanced prompt with mode context (needed for skill loading)
    ENHANCED_PROMPT="[MODE: $MODE] [SKILLS: "
    case $MODE in
      chat) ENHANCED_PROMPT+="orchestration/context/communication/topic-switcher" ;;
      thinker) ENHANCED_PROMPT+="architecture/planning/research/validation" ;;
      coder) ENHANCED_PROMPT+="coding/refactoring/testing/git" ;;
      debug) ENHANCED_PROMPT+="debugging/testing/performance/system-health" ;;
      research) ENHANCED_PROMPT+="research/web-search/data-analysis/documentation" ;;
      *) ENHANCED_PROMPT+="general" ;;
    esac
    ENHANCED_PROMPT+="] ${PROMPT_ARGS[*]}"

    # Start all Node.js processes in parallel (background)
    PIDS=()
    
    # 1. Smart skill loader (shows UI feedback, runs first)
    echo ""
    node bin/smart-skill-loader-fixed.js --mode "$MODE" --message "${PROMPT_ARGS[*]}" 2>&1 &
    SKILL_PID=$!
    PIDS+=($SKILL_PID)
    
    # 2. Token dashboard (runs in background)
    node bin/token-dashboard.js --mode "$MODE" 2>&1 &
    TOKEN_PID=$!
    PIDS+=($TOKEN_PID)
    
    # 3. Pre-capture conversation (runs in background, before OpenCode)
    node bin/capture-conversation.js capture "${PROMPT_ARGS[*]} (Mode: $MODE, Starting query)" "wzrd-query" 2>/dev/null &
    CAPTURE_PID=$!
    PIDS+=($CAPTURE_PID)
    
    # Wait for smart skill loader to complete (it shows UI)
    wait $SKILL_PID
    echo ""
    
    # Run OpenCode command (main execution)
    opencode --model "$MODEL" $AGENT run "$ENHANCED_PROMPT"
    EXIT_CODE=$?
    
    # Wait for remaining background processes
    wait $TOKEN_PID $CAPTURE_PID 2>/dev/null || true
    echo ""

    # Post-execution capture if successful
    if [[ $EXIT_CODE -eq 0 ]]; then
      echo "💾 Capturing successful conversation to memory..."
      node bin/capture-conversation.js capture "${PROMPT_ARGS[*]} (Mode: $MODE, Response successful)" "wzrd-query" 2>/dev/null &
    fi

    exit $EXIT_CODE
  fi