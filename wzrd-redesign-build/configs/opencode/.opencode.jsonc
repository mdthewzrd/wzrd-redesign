{
  "$schema": "https://opencode.ai/config.json",
  
  "permission": {
    "*": "allow",
    
    "bash": {
      "*": "allow"
    },
    
    "read": {
      "*": "allow"
    },
    "edit": {
      "*": "allow"
    },
    "write": {
      "*": "allow"
    },
    "glob": {
      "*": "allow"
    },
    "grep": {
      "*": "allow"
    },
    "list": {
      "*": "allow"
    },
    
    "task": "allow",
    "skill": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    
    "external_directory": {
      "/home/mdwzrd/wzrd-redesign/**": "allow",
      "/home/mdwzrd/wzrd.dev/**": "allow",
      "~/.claude/**": "allow",
      "~/.opencode/**": "allow"
    },
    
    "doom_loop": "ask"
  },
  
  "agent": {
    "remi": {
      "permission": {
        "*": "allow",
        "bash": {
          "*": "allow"
        }
      }
    }
  }
}
